{
    "version": "2.0.0",
    "options": {
        "shell": {
            "executable": "/bin/bash",
            "args": [
                "-lc"
            ]
        }
    },
    "tasks": [
        {
            "label": "1. Live Data Stream",
            "type": "shell",
            "command": "uv run historical_live_stream.py",
            "isBackground": true,
            "problemMatcher": {
                "owner": "finance-analyst",
                "pattern": [
                    {
                        "regexp": "a^"
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "HISTORICAL \\+ LIVE MARKET DATA STREAM",
                    "endsPattern": "LIVE STREAMING STARTED"
                }
            },
            "presentation": {
                "group": "finance-analyst",
                "panel": "dedicated"
            }
        },
        {
            "label": "2. Market Analyzer",
            "type": "shell",
            "command": "uv run analyze_and_report.py --watch",
            "isBackground": true,
            "problemMatcher": {
                "owner": "finance-analyst",
                "pattern": [
                    {
                        "regexp": "a^"
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "MARKET DATA ANALYZER & REPORT GENERATOR",
                    "endsPattern": "WATCH MODE: Monitoring CSV file"
                }
            },
            "presentation": {
                "group": "finance-analyst",
                "panel": "dedicated"
            }
        },
        {
            "label": "3. AI Insight Watcher",
            "type": "shell",
            "command": "uv run ai_watch_report.py reports/ --watch",
            "isBackground": true,
            "problemMatcher": {
                "owner": "finance-analyst",
                "pattern": [
                    {
                        "regexp": "a^"
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "AI REPORT WATCHER & INSIGHTS GENERATOR",
                    "endsPattern": "WATCH MODE: Monitoring for new reports"
                }
            },
            "presentation": {
                "group": "finance-analyst",
                "panel": "dedicated"
            }
        },
        {
            "label": "🚀 Run AI Finance Suite",
            "dependsOrder": "parallel",
            "dependsOn": [
                "1. Live Data Stream",
                "2. Market Analyzer",
                "3. AI Insight Watcher"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "finance-analyst"
            }
        }
    ]
}
